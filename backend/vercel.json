{
    "version": 2,
    "functions": {
      "api/index.php": {
        "runtime": "vercel-php@0.8.0"
      }
    },
    "routes": [
      {
        "src": "/(.*)",
        "dest": "api/index.php"
      }
    ],
    "env": {
      "VIEW_COMPILED_PATH": "/tmp",
      "CACHE_DRIVER": "array",
      "SESSION_DRIVER": "array"
    }
  }